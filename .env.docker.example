# 应用运行环境。生产部署请保持 production，并关闭调试模式。
APP_ENV=production
# 应用加密密钥。首次部署时按文档生成，生成后不要随意更换。
APP_KEY=
APP_DEBUG=false
# 日志按天轮转，仅记录错误及以上级别。
APP_LOG=daily
APP_LOG_LEVEL=error

# 对外访问地址，必须填写由外部反向代理提供的 HTTPS 域名。
APP_URL=https://cards.example.com
APP_URL_API=https://cards.example.com
# 宿主机公开的 HTTP 端口，外部 HTTPS 反向代理应转发到此端口。
HTTP_PORT=8080
# 要部署的 GHCR 镜像标签。latest 对应 master 最新版本，也可使用 sha-完整提交SHA。
IMAGE_TAG=latest
# 可信反向代理的 IP 或 CIDR，多个地址使用英文逗号分隔，禁止填写 *。
TRUSTED_PROXIES=127.0.0.1

# MySQL 数据库配置。生产环境必须替换下面的示例密码。
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=card_system
DB_USERNAME=card_system
DB_PASSWORD=change_this_database_password
# MySQL root 密码仅用于数据库容器初始化和健康检查。
MYSQL_ROOT_PASSWORD=change_this_root_password

# Redis 用于缓存、会话和异步队列，仅在 Compose 内部网络开放。
REDIS_HOST=redis
# 未启用 Redis 密码时保持 null；如启用密码，需要同步修改 Redis 服务启动参数。
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_DRIVER=redis

# API 自动发货商品使用的外部数据库。不使用此功能时保持为空。
API_CARD_DB_HOST=
API_CARD_DB_PORT=3306
API_CARD_DB_DATABASE=
API_CARD_DB_USERNAME=
API_CARD_DB_PASSWORD=
