APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_LOG=daily
APP_LOG_LEVEL=error

# This URL must be the public HTTPS URL handled by the external reverse proxy.
APP_URL=https://cards.example.com
APP_URL_API=https://cards.example.com
HTTP_PORT=8080
IMAGE_TAG=latest
TRUSTED_PROXIES=127.0.0.1

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=card_system
DB_USERNAME=card_system
DB_PASSWORD=change_this_database_password
MYSQL_ROOT_PASSWORD=change_this_root_password

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_DRIVER=redis

# Optional external database used by DELIVERY_API products.
API_CARD_DB_HOST=
API_CARD_DB_PORT=3306
API_CARD_DB_DATABASE=
API_CARD_DB_USERNAME=
API_CARD_DB_PASSWORD=
